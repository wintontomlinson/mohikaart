# Copy to `.env` and fill in your Supabase project values.
# These are the publishable (anon) keys — safe to ship to the browser
# AS LONG AS your RLS policies are correct (see migrations/).
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"
